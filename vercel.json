{
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "https://elaichi.up.railway.app/auth/:path*"
    },
    {
      "source": "/fetch/:path*",
      "destination": "https://elaichi.up.railway.app/fetch/:path*"
    },
    {
      "source": "/((?!assets|images|favicon.svg|icons.svg).*)",
      "destination": "/index.html"
    }
  ]
}
